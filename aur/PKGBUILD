pkgname=paperpass
pkgver=1.1.11
pkgrel=3
pkgdesc="Paperpass Arch Package"
url="https://codeberg.org/rigel254/paperpass"
# source=("$pkgname::git+$url#branch=main")
# source=("$pkgname::git+$url#tag=$pkgver")
# for source local
source=("$pkgname::git+file://${PWD}/../")

arch=(x86_64 arm armv7h armv6h aarch64)
# arch=(x86_64)

makedepends=(git rust)
# depends=(git rust)

sha256sums=('SKIP')
options=(!debug)

build () {
  cd "$pkgname"

  # if [[ $CARCH != x86_64 ]]; then
  #   export CARGO_PROFILE_RELEASE_LTO=off
  # fi
  # cargo build --locked --profile release-small -j2
  # cargo build --offline --profile release-small -j2
  cargo build --profile release-small -j`nproc 2>/dev/null || getconf _NPROCESSORS_CONF`
}

package() {
  cd "$pkgname"
  install -vDm755 -t "$pkgdir/usr/local/bin/" target/release-small/paperpass
}
